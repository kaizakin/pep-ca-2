PORT=4000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# MongoDB — when using docker-compose, use the MongoDB service hostname
MONGODB_URI=mongodb://localhost:27017/devtrackr

# Generate with: openssl rand -base64 32
JWT_SECRET=change-me-to-a-random-string-at-least-24-chars
# Generate with: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=change-me-to-a-random-string-at-least-16-chars

GITHUB_CLIENT_ID=your-github-oauth-app-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-app-client-secret
GITHUB_WEBHOOK_SECRET=

GEMINI_API_KEY=your-google-gemini-api-key

# Cron expression for the analytics background worker (default: every 15 minutes)
ANALYTICS_CRON=*/15 * * * *
